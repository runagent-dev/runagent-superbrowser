# ─────────────────────────────────────────────────────────────────────
# SuperBrowser configuration template
#
# Copy this file to .env and fill in the values you care about. Every
# variable here is optional unless explicitly noted — SuperBrowser runs
# with zero config on port 3100 using a bundled Chromium.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════
# Core server
# ═══════════════════════════════════════════════════════════════════

PORT=3100

# Bearer token for protected endpoints (/function, /session/:id/script).
# Leave blank to run without auth (local dev only — don't expose to
# the public internet without setting this).
# TOKEN=

# Headless Chromium. Set to "false" to watch the browser locally.
HEADLESS=true

# Custom Chromium binary path. Leave unset to use Puppeteer's bundled
# Chromium, or point at /usr/bin/google-chrome-stable etc.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

DOWNLOAD_DIR=/tmp/superbrowser/downloads

# Concurrency limits.
CONCURRENT=10
QUEUED=10
TIMEOUT=60000

MAX_SESSIONS=20
RATE_LIMIT=200
TASK_TIMEOUT=300000

# Public base URL of the /session/:id/view UI. Required when the server
# is behind a proxy or on a remote host — otherwise the live-view URL
# surfaced to humans would be a relative path that they can't open.
# SUPERBROWSER_PUBLIC_HOST=https://browser.example.com

# Persistent browser profile + cookie directory — durable across
# restarts, separate from the captcha cookie jar below.
BROWSER_PROFILE=/root/.superbrowser-profile
COOKIE_DIR=/root/.superbrowser-cookies

# CORS — leave disabled for local dev.
# CORS=true
# CORS_ALLOW_ORIGIN=https://yourdomain.com

# Optional URL firewall (comma-separated domains).
# FIREWALL_ALLOW_LIST=example.com,github.com
# FIREWALL_DENY_LIST=evil.example.com


# ═══════════════════════════════════════════════════════════════════
# Captcha + human handoff
# ═══════════════════════════════════════════════════════════════════

# External captcha solvers (optional — only used for token / grid API
# methods). Pick 2captcha or anticaptcha.
# CAPTCHA_PROVIDER=2captcha
# CAPTCHA_API_KEY=your-solver-api-key

# Fast-to-human policy: one auto-solve attempt, then immediately hand
# off to the live-view UI. Avoids the ping pattern that gets sessions
# fingerprinted as bots. Leave unset for the default 7-strategy ladder.
# SUPERBROWSER_CAPTCHA_POLICY=fast_to_human

# Max human handoffs per session (default 1).
# SUPERBROWSER_MAX_HUMAN_HANDOFFS=1

# Per-(task, domain) persistence of bot-protection cookies
# (cf_clearance, __cf_bm, datadome, Akamai _abck, etc.). Set to 1 so a
# human only has to solve once per site per task.
# SUPERBROWSER_COOKIE_JAR=1
# SUPERBROWSER_COOKIE_JAR_PATH=/root/.superbrowser/cookie-jar

# Scope key for the cookie jar + handoff ledger. Pass a stable task ID
# if you want warm-starts on the same task to reuse persisted state.
# SUPERBROWSER_TASK_ID=my-task-id

# Fired when a human is needed. Receives JSON with viewUrl, captchaType,
# pageTitle, screenshot (b64), and a pre-formatted caption — plug this
# into your WhatsApp / Slack / Telegram bridge.
# HANDOFF_WEBHOOK_URL=https://your-bot.example.com/webhooks/handoff


# ═══════════════════════════════════════════════════════════════════
# Vision preprocessor (Python side — nanobot/vision_agent/)
#
# When enabled, screenshots are converted to text + bboxes by a cheap
# dedicated vision model BEFORE they reach the nanobot brain. Dramatic
# cost drop on observational iterations.
# ═══════════════════════════════════════════════════════════════════

# Vision middleman defaults to ON whenever VISION_API_KEY is set.
# Explicitly set VISION_ENABLED=0 to disable even with a key present,
# or VISION_ENABLED=1 to force-on (backward compat).
# VISION_ENABLED=1

# Which provider the openai SDK routes to. All three use the same SDK
# (different baseURL): openai → default, openrouter → their endpoint,
# gemini → Google's OpenAI-compat endpoint.
# VISION_PROVIDER=openai

# Model identifier the provider accepts.
#   openai      → gpt-4o-mini
#   openrouter  → openai/gpt-4o-mini, google/gemini-flash-1.5, etc.
#   gemini      → gemini-2.0-flash-exp, gemini-3-flash-preview, etc.
# VISION_MODEL=gpt-4o-mini

# SEPARATE key — do NOT reuse the nanobot brain's API key here.
# Keeping this isolated prevents image tokens from leaking onto the
# expensive reasoning model's bill.
# VISION_API_KEY=

# Optional overrides.
# VISION_BASE_URL=
# VISION_CACHE_SIZE=200
# VISION_CACHE_TTL_SEC=300
# VISION_MAX_TOKENS=1500
# VISION_MAX_BBOXES=30
# VISION_TIMEOUT_MS=8000


# ═══════════════════════════════════════════════════════════════════
# Tier 3 (undetected Chromium) — antibot pipeline
# ═══════════════════════════════════════════════════════════════════

# Patchright chromium runs headless by default. Set to 0 when you have
# a display (Xvfb in containers) — some hardened Akamai targets check
# for real-window-size signals that headless can't provide.
# T3_HEADLESS=1

# Tier-3 sessions expose a live viewer for human handoff on a separate
# port from the TS server (:3100). Pick any free port.
# SUPERBROWSER_T3_VIEWER_PORT=3101

# Optional residential proxy pool. When set, the proxy_tiers module
# auto-demotes hardened domains (Akamai / DataDome etc.) from the
# datacenter PROXY_POOL to this list on detected blocks.
# PROXY_POOL_RESIDENTIAL=http://user:pass@resi.example.com:8080

# Cloudflare challenge wait timeout (seconds). Tier-3 polls for
# clearance cookies (cf_clearance, __cf_bm) and redirect-away-from
# challenge URL for up to this long before either calling the Turnstile
# auto-solver (if CAPTCHA_API_KEY is set) or retrying once with a fresh
# context and different UA.
# T3_CF_WAIT_S=30

# Fixed UA profile for Tier 3 sessions. Leave unset to pick randomly
# from the chrome124_mac / chrome124_linux / chrome125_* / chrome126_*
# table each session. Pin a specific profile when debugging a site that
# only works with a specific Chrome build.
# T3_UA_PROFILE=chrome124_mac

# CAPTCHA_API_KEY triggers automatic Turnstile solve inside the Tier 3
# navigate path when a Cloudflare challenge doesn't auto-clear. Shared
# with the existing browser_solve_captcha tool — same env, same budget.
# Set CAPTCHA_PROVIDER to 2captcha | anticaptcha | nopecha.
# CAPTCHA_PROVIDER=2captcha
# CAPTCHA_API_KEY=...


# ═══════════════════════════════════════════════════════════════════
# Built-in agent (only needed if you hit POST /task)
#
# SuperBrowser itself does NOT require an LLM key. These only matter
# if you want the autonomous Navigator+Planner agent at /task. Nanobot
# integrations bring their own LLM config separately.
# ═══════════════════════════════════════════════════════════════════

# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=gpt-4o
