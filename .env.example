# SuperBrowser Configuration
#
# Copy this file to .env and fill in the values you care about. Every
# variable here is optional unless explicitly noted — SuperBrowser runs
# with zero config on port 3100 using a bundled Chromium.
#
#   cp .env.example .env

# Authentication. When TOKEN is set, /session/:id/script and /function are
# unlocked, and all incoming requests must carry `Authorization: Bearer <TOKEN>`.
# The Python bridge (_request_with_backoff in session_tools.py) injects this
# header automatically when SUPERBROWSER_TOKEN env var is set.
TOKEN=sb-local-dev-change-me
SUPERBROWSER_TOKEN=sb-local-dev-change-me

# Server
PORT=3100

# Browser
HEADLESS=true
DOWNLOAD_DIR=/tmp/superbrowser/downloads

# Concurrency
CONCURRENT=10
QUEUED=10
TIMEOUT=60000

# Sessions
MAX_SESSIONS=20
# SESSION_IDLE_TIMEOUT and SESSION_MAX_LIFETIME are hardcoded (30min / 2hr)

# Rate limiting (requests per IP per minute)
RATE_LIMIT=200

# Task execution timeout (ms) for /task endpoint
TASK_TIMEOUT=300000

# Captcha solving (required for Cloudflare Turnstile bypass).
# Sign up at https://2captcha.com or https://anti-captcha.com and paste
# the API key here. Provider options: 2captcha | anticaptcha | nopecha.
CAPTCHA_PROVIDER=2captcha
# CAPTCHA_API_KEY=your-2captcha-api-key-here

# Persistent browser profile — retains cf_clearance cookies across restarts
BROWSER_PROFILE=/root/.superbrowser-profile

# Cookie persistence directory (durable across restarts)
COOKIE_DIR=/root/.superbrowser-cookies

# Chromium path. Leave unset to use Puppeteer's bundled Chromium, or
# point at /usr/bin/google-chrome-stable for the hardest fingerprint
# targets. See README "Install Chrome" section.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Public base URL of the /session/:id/view UI. Required when the server
# is behind a proxy or on a remote host — otherwise the live-view URL
# surfaced to humans would be a relative path that they can't open.
# SUPERBROWSER_PUBLIC_HOST=https://browser.example.com

# CORS (disabled by default — set specific origin for production)
# CORS=true
# CORS_ALLOW_ORIGIN=https://yourdomain.com

# Optional URL firewall (comma-separated domains).
# FIREWALL_ALLOW_LIST=example.com,github.com
# FIREWALL_DENY_LIST=evil.example.com

# Fired when a human is needed. Receives JSON with viewUrl, captchaType,
# pageTitle, screenshot (b64), and a pre-formatted caption — plug this
# into your WhatsApp / Slack / Telegram bridge.
# HANDOFF_WEBHOOK_URL=https://your-bot.example.com/webhooks/handoff

# LLM — enables AI vision captcha solving (screenshot -> LLM analyzes -> clicks tiles)
# Also needed for /task endpoint built-in Navigator+Planner.
# These same keys configure the nanobot brain for the Python SDK: SuperBrowser()
# bridges LLM_MODEL + a provider key (or the LLM_PROVIDER/LLM_API_KEY contract) into
# ~/.nanobot/config.json on first run. `nanobot onboard` is the alternative; see
# docs/sdk.md → "Configuration & .env" for the precedence.
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o

# Vision preprocessor agent — cheap vision model runs on the Python side
# (nanobot/vision_agent/) and converts screenshots into text + bboxes
# BEFORE they reach the nanobot brain. When enabled, browser tools
# return text-only tool results; nanobot never pays image tokens.
# Unset VISION_ENABLED to fall back to the legacy image-blocks path.
VISION_ENABLED=1
# Provider: openai | openrouter | gemini (all three routed through the
# openai SDK with per-provider baseURL).
VISION_PROVIDER=gemini
# Model accepted by that provider, e.g.
#   openai      → gpt-4o-mini
#   openrouter  → openai/gpt-4o-mini  (or google/gemini-flash-1.5, ...)
#   gemini      → gemini-2.0-flash-exp
VISION_MODEL=gemini-2.0-flash-exp
# SEPARATE API key — do NOT reuse the nanobot brain's key here. Keeping
# this isolated prevents image tokens from leaking onto the expensive
# reasoning model's bill.
# VISION_API_KEY=your-vision-key-here

# Optional overrides — leave blank to use provider defaults.
# VISION_BASE_URL=
# VISION_CACHE_SIZE=200
# VISION_CACHE_TTL_SEC=300
# VISION_MAX_TOKENS=1500
# VISION_MAX_BBOXES=30
# VISION_TIMEOUT_MS=8000
VISION_SOM_OVERLAY=1

SUPERBROWSER_CLICK_MODE=fast
SUPERBROWSER_VISION_REFRESH_S=3
VISION_CACHE_TTL_SEC=30

# Residential proxy. Setting on BOTH tiers because proxy_tiers.pick() goes
# direct on first contact when tier-0 (PROXY_POOL) is empty — that route
# bypasses the proxy until 2 consecutive CF failures demote the domain.
# With the proxy on tier 0, every request egresses through it from the
# first hit, which is what cars.com-class sites need.
# PROXY_POOL=http://user:pass@host:port
# PROXY_POOL_RESIDENTIAL=http://user:pass@host:port

# Per-(task, domain) persistence of bot-protection cookies
# (cf_clearance, __cf_bm, datadome, Akamai _abck, etc.). Set to 1 so a
# human only has to solve once per site per task.
# SUPERBROWSER_COOKIE_JAR=1
# SUPERBROWSER_COOKIE_JAR_PATH=/root/.superbrowser/cookie-jar

# Scope key for the cookie jar + handoff ledger. Pass a stable task ID
# if you want warm-starts on the same task to reuse persisted state.
# SUPERBROWSER_TASK_ID=my-task-id

# Fast-to-human policy: one auto-solve attempt, then immediately hand
# off to the live-view UI. Avoids the ping pattern that gets sessions
# fingerprinted as bots. Leave unset for the default 7-strategy ladder.
# SUPERBROWSER_CAPTCHA_POLICY=fast_to_human

# Max human handoffs per session (default 1).
# SUPERBROWSER_MAX_HUMAN_HANDOFFS=1


# --- T3 (patchright / undetected Chromium) fingerprint upgrades ----------

# Real Chrome binary instead of bundled Chromium. For maximum stealth
# install consumer Google Chrome via the apt repo (see README "Install
# Chrome" section).
CHROME_PATH=/usr/bin/google-chrome-stable
# CHROME_CHANNEL=chrome  # Playwright-native selector; only set if you
                        # use the distro Chrome package that registers
                        # itself as a Playwright channel.

# Per-domain persistent browser profile (user-data-dir). Gives CF real
# localStorage/IndexedDB/service-worker continuity across tasks — the
# single strongest auto-pass signal. Profile dir: ~/.superbrowser/profiles/
T3_PERSIST_PROFILE=1
# T3_PROFILE_ROOT=/root/.superbrowser/profiles   # override default
# T3_PROFILE_MAX_MB=200                          # per-profile size cap

# Headful + Xvfb: flip when a target (cars.com class) still gets
# challenged with the real-Chrome + persistent-profile combo. Xvfb
# auto-spawns if not already running.
#
# DISPLAY MUST be exported in this .env (not just left to auto-spawn) —
# Playwright's Node host snapshots env at start(); any later
# os.environ["DISPLAY"]=... mutation in _maybe_start_xvfb arrives too
# late for Chrome's subprocess. Setting it here lets superbrowser_bridge/
# __init__.py load it via dotenv BEFORE async_playwright().start() runs.
T3_HEADLESS=0
T3_AUTO_XVFB=1
T3_XVFB_DISPLAY=:99
DISPLAY=:99

# Tier-3 sessions expose a live viewer for human handoff on a separate
# port from the TS server (:3100). Pick any free port.
# SUPERBROWSER_T3_VIEWER_PORT=3101

# HTTP/2 toggle. Forces --disable-http2 in the launch args by default —
# needed for Imperva-fronted hosts that reject non-allowlisted HTTP/2
# frames (cars.com class). Set 0 to re-enable HTTP/2.
# T3_DISABLE_HTTP2=1

# Cloudflare challenge wait timeout (seconds). Tier-3 polls for
# clearance cookies (cf_clearance, __cf_bm) and redirect-away-from
# challenge URL for up to this long before either calling the Turnstile
# auto-solver (if CAPTCHA_API_KEY is set) or retrying once with a fresh
# context and different UA.
# T3_CF_WAIT_S=30
# T3_CF_SOLVER_WAIT_S=60

# Fixed UA profile for Tier 3 sessions. Leave unset to pick randomly
# from the chrome124_mac / chrome124_linux / chrome125_* / chrome126_*
# table each session.
# T3_UA_PROFILE=chrome124_mac

# Disable per-domain learnings reads (the router's memory of which
# tier worked where). Set to 1 to force every domain to start at the
# cheapest tier regardless of past failures.
LEARNING_READS_ENABLED=0
